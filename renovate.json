{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
  "schedule": ["before 7pm on monday through thuesday"],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 1,
  "minimumReleaseAge": "1 year",
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev dependencies (all)",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dependencies (patch, minor)",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchPackageNames": ["axios"],
      "enabled": false
    },
    {
      "matchPackageNames": ["axios"],
      "matchUpdateTypes": ["patch"],
      "enabled": true
    }
  ]
}
