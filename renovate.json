{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["*"], // kann man auch weglassen?
      "groupName": "dev dependencies (all)",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDepTypes": ["*"], // kann man auch weglassen?
      "matchUpdateTypes": ["patch"],
      "groupName": "dependencies (patch)",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchPackageNames": ["axios"],
      "matchUpdateTypes": ["patch"],
      "enabled": true
    }
  ]
}
